        "set": "Hot Work",
        "gear": [
          "hot_work_exo_rig",
          "hot_work_hands_ppe",
          "hot_work_insulation_slab",
          "lynx_slab"
        ],
        "alts": [
          "wpn_funnel_0009"
        ],
        "note": {
          "es": "Modo daño. Subestadísticas: Intellect (mantenlo por encima del Will para no salir de la forma) y Will. El cuarto slot es una LYNX Slab suelta por el atributo principal.",
          "en": "Damage mode. Substats: Intellect (keep it above Will so you stay in form) and Will. The fourth slot is a loose LYNX Slab for the main attribute."
        }
      },
      {
        "label": {
          "es": "Forma WILL — Soporte",
          "en": "WILL form — Support"
        },
